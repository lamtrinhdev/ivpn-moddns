[
  {
    "update": "profiles",
    "updates": [
      {
        "q": {
          "settings.custom_rules": { "$exists": true },
          "settings.user_rules": { "$exists": false }
        },
        "u": {
          "$rename": {
            "settings.custom_rules": "settings.user_rules"
          }
        },
        "multi": true
      }
    ],
    "writeConcern": { "w": "majority" }
  }
]
